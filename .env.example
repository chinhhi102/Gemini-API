# Copy to .env and fill in. Never commit the real .env.

# Shared secret. Used as the `X-API-Key` header for the admin UI and /generate.
SERVICE_API_KEY=change-me-to-a-long-random-string

# Accounts are normally added through the admin UI (no cookies needed here).
# These two are an OPTIONAL one-time seed: on a fresh data volume they create
# the first account automatically. Leave blank to add everything via the UI.
GEMINI_SECURE_1PSID=
GEMINI_SECURE_1PSIDTS=

# Optional: outbound proxy, e.g. http://user:pass@host:port
GEMINI_PROXY=

# ===== Media =====
# Strip Gemini's visible corner watermark from ALL generated images, regardless
# of the per-request remove_watermark flag. ON by default. When on, requests
# that ask for media=url are upgraded to stream (the bytes must be downloaded to
# be cleaned). Set to false to make watermark removal strictly opt-in per request.
FORCE_REMOVE_WATERMARK=true
# How long streamed media (media=stream) is kept on disk before eviction, seconds.
MEDIA_CACHE_TTL=900

# ===== Async jobs (POST /jobs) =====
# Job state backend: set REDIS_URL to use Redis, else a local JSON file is used.
# e.g. redis://localhost:6379/0  (or redis://:password@host:6379/0)
REDIS_URL=
# File-backed job store path (used only when REDIS_URL is unset).
JOBS_PATH=
# Number of background workers draining the job queue (bounds concurrency).
JOB_WORKERS=3
# How long completed/failed jobs are kept before eviction (seconds).
JOB_TTL=86400
# Webhook callback delivery (per-job callback_url): request timeout and retries.
JOB_CALLBACK_TIMEOUT=15
JOB_CALLBACK_RETRIES=3
