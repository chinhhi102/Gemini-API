# Copy to .env and fill in. Never commit the real .env.

# Shared secret. Used as the `X-API-Key` header for the admin UI and /generate.
SERVICE_API_KEY=change-me-to-a-long-random-string

# Accounts are normally added through the admin UI (no cookies needed here).
# These two are an OPTIONAL one-time seed: on a fresh data volume they create
# the first account automatically. Leave blank to add everything via the UI.
GEMINI_SECURE_1PSID=
GEMINI_SECURE_1PSIDTS=

# Optional: outbound proxy, e.g. http://user:pass@host:port
GEMINI_PROXY=
