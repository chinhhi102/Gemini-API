{
  "openapi": "3.1.0",
  "info": {
    "title": "Gemini Web Service",
    "summary": "Multi-account Gemini proxy. Pass-through: returns Gemini's response as-is.",
    "version": "2.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/models": {
      "get": {
        "summary": "Models",
        "operationId": "models_models_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Models Models Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/accounts": {
      "get": {
        "summary": "List Accounts",
        "operationId": "list_accounts_api_accounts_get",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "default": "",
              "title": "X-Api-Key"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountList"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add Account",
        "operationId": "add_account_api_accounts_post",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "default": "",
              "title": "X-Api-Key"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountIn"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/accounts/{account_id}": {
      "patch": {
        "summary": "Patch Account",
        "operationId": "patch_account_api_accounts__account_id__patch",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Account Id"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "default": "",
              "title": "X-Api-Key"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountPatch"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete Account",
        "operationId": "delete_account_api_accounts__account_id__delete",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Account Id"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "default": "",
              "title": "X-Api-Key"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/accounts/{account_id}/test": {
      "post": {
        "summary": "Test Account",
        "operationId": "test_account_api_accounts__account_id__test_post",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Account Id"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "default": "",
              "title": "X-Api-Key"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TestResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/test": {
      "post": {
        "summary": "Test Cookies",
        "operationId": "test_cookies_api_test_post",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "default": "",
              "title": "X-Api-Key"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CookieTest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TestResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/generate": {
      "post": {
        "summary": "Generate",
        "operationId": "generate_generate_post",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "default": "",
              "title": "X-Api-Key"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccountIn": {
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "title": "Label"
          },
          "secure_1psid": {
            "type": "string",
            "minLength": 1,
            "title": "Secure 1Psid"
          },
          "secure_1psidts": {
            "type": "string",
            "title": "Secure 1Psidts",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "label",
          "secure_1psid"
        ],
        "title": "AccountIn"
      },
      "AccountList": {
        "properties": {
          "accounts": {
            "items": {
              "$ref": "#/components/schemas/AccountOut"
            },
            "type": "array",
            "title": "Accounts",
            "default": []
          }
        },
        "type": "object",
        "title": "AccountList"
      },
      "AccountOut": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled"
          },
          "priority": {
            "type": "integer",
            "title": "Priority"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "untested | ok | error"
          },
          "status_detail": {
            "type": "string",
            "title": "Status Detail",
            "default": ""
          },
          "updated_at": {
            "type": "string",
            "title": "Updated At",
            "default": ""
          },
          "secure_1psid": {
            "type": "string",
            "title": "Secure 1Psid",
            "description": "Masked \u2014 last 4 chars only",
            "default": ""
          },
          "secure_1psidts": {
            "type": "string",
            "title": "Secure 1Psidts",
            "description": "Masked \u2014 last 4 chars only",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "id",
          "label",
          "enabled",
          "priority",
          "status"
        ],
        "title": "AccountOut"
      },
      "AccountPatch": {
        "properties": {
          "label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Label"
          },
          "enabled": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Enabled"
          },
          "priority": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Priority"
          },
          "secure_1psid": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Secure 1Psid"
          },
          "secure_1psidts": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Secure 1Psidts"
          }
        },
        "type": "object",
        "title": "AccountPatch"
      },
      "CookieTest": {
        "properties": {
          "secure_1psid": {
            "type": "string",
            "minLength": 1,
            "title": "Secure 1Psid"
          },
          "secure_1psidts": {
            "type": "string",
            "title": "Secure 1Psidts",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "secure_1psid"
        ],
        "title": "CookieTest"
      },
      "DeleteResult": {
        "properties": {
          "deleted": {
            "type": "string",
            "title": "Deleted"
          }
        },
        "type": "object",
        "required": [
          "deleted"
        ],
        "title": "DeleteResult"
      },
      "GenerateRequest": {
        "properties": {
          "prompt": {
            "type": "string",
            "minLength": 1,
            "title": "Prompt",
            "description": "User text prompt"
          },
          "model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model",
            "description": "Model name, e.g. 'gemini-3-pro'"
          }
        },
        "type": "object",
        "required": [
          "prompt"
        ],
        "title": "GenerateRequest"
      },
      "GenerateResponse": {
        "properties": {
          "account": {
            "type": "string",
            "title": "Account",
            "description": "Label of the account that served the request"
          },
          "text": {
            "type": "string",
            "title": "Text",
            "default": ""
          },
          "thoughts": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Thoughts"
          },
          "images": {
            "items": {
              "$ref": "#/components/schemas/ImageOut"
            },
            "type": "array",
            "title": "Images",
            "default": []
          },
          "videos": {
            "items": {
              "$ref": "#/components/schemas/VideoOut"
            },
            "type": "array",
            "title": "Videos",
            "default": []
          },
          "audio": {
            "items": {
              "$ref": "#/components/schemas/MediaOut"
            },
            "type": "array",
            "title": "Audio",
            "default": []
          },
          "metadata": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Metadata",
            "description": "[chat_id, reply_id, ...]",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "account"
        ],
        "title": "GenerateResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ImageOut": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url",
            "description": "Original Gemini image URL"
          },
          "title": {
            "type": "string",
            "title": "Title",
            "default": ""
          },
          "alt": {
            "type": "string",
            "title": "Alt",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "ImageOut"
      },
      "MediaOut": {
        "properties": {
          "mp4_url": {
            "type": "string",
            "title": "Mp4 Url",
            "description": "Original mp4 URL, if any",
            "default": ""
          },
          "mp3_url": {
            "type": "string",
            "title": "Mp3 Url",
            "description": "Original audio (mp3) URL, if any",
            "default": ""
          },
          "title": {
            "type": "string",
            "title": "Title",
            "default": ""
          },
          "thumbnail": {
            "type": "string",
            "title": "Thumbnail",
            "default": ""
          },
          "mp3_thumbnail": {
            "type": "string",
            "title": "Mp3 Thumbnail",
            "default": ""
          }
        },
        "type": "object",
        "title": "MediaOut"
      },
      "TestResult": {
        "properties": {
          "ok": {
            "type": "boolean",
            "title": "Ok"
          },
          "detail": {
            "type": "string",
            "title": "Detail"
          }
        },
        "type": "object",
        "required": [
          "ok",
          "detail"
        ],
        "title": "TestResult"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "VideoOut": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url",
            "description": "Original Gemini video (mp4) URL"
          },
          "title": {
            "type": "string",
            "title": "Title",
            "default": ""
          },
          "thumbnail": {
            "type": "string",
            "title": "Thumbnail",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "VideoOut"
      }
    }
  }
}